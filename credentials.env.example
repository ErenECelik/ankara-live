# Polymarket CLOB Kimlik Bilgileri
# Bu dosyayı credentials.env olarak kopyala ve doldur:
#   cp credentials.env.example credentials.env
#
# credentials.env asla git'e ekleme — .gitignore'a ekle!

# ── Ethereum cüzdan ───────────────────────────────────────────────
# Polymarket'te işlem yapan cüzdanın private key'i (0x ile başlar)
CLOB_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Proxy wallet (MetaMask ile Polymarket'e bağlananlar için) ─────
# Polymarket UI'da görünen adres — signature_type=2 ile kullanılır
# MetaMask olmadan direkt private key ile kurulduysa bu satırı sil
CLOB_FUNDER=0xYOUR_POLYMARKET_PROXY_ADDRESS

# ── CLOB API key (derive_api_key() ile türetilir) ─────────────────
# İlk kurulumda:  python -c "from clob import derive_api_key; derive_api_key('0xYOUR_KEY')"
# Çıktıdaki değerleri buraya yapıştır:
CLOB_API_KEY=your-api-key-here
CLOB_API_SECRET=your-api-secret-here
CLOB_API_PASSPHRASE=your-api-passphrase-here

# ── Mod ───────────────────────────────────────────────────────────
# true  → emirleri sadece logla, GÖNDERME (güvenli test modu)
# false → gerçek emirler gönder (CANLI)
DRY_RUN=true
